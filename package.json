{
  "name": "ai-prompt-enhancer-extension",
  "description": "A privacy-first Chrome extension for enhancing prompts with Skills and multiple AI providers.",
  "private": true,
  "version": "0.1.1",
  "license": "MIT",
  "keywords": ["chrome-extension", "prompt-engineering", "ai", "productivity", "typescript"],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "test": "vitest",
    "test:run": "vitest run",
    "preview": "vite preview",
    "test:e2e": "npm run build && node scripts/e2e.mjs"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.7.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.2.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  }
}
